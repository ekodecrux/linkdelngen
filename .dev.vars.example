# LinkedBoost AI - Environment Variables Template
# Copy this file to .dev.vars and fill in your credentials
# .dev.vars is gitignored and never committed

# Groq AI (get from console.groq.com)
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# Twilio SMS OTP (get from console.twilio.com)
TWILIO_ACCOUNT_SID=AC_YOUR_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
TWILIO_SERVICE_SID=VA_YOUR_SERVICE_SID_HERE

# Gmail SMTP (use App Password from myaccount.google.com/apppasswords)
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# JWT Secret (any random string)
JWT_SECRET=linkedboost-ai-secret-2025

# Razorpay Payment Gateway (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# Cloudflare Deployment (get from dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=cfut_YOUR_API_TOKEN_HERE
CLOUDFLARE_ACCOUNT_ID=YOUR_ACCOUNT_ID_HERE
